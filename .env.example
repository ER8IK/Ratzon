BOT_TOKEN=
LOG_LEVEL=INFO
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# QVAC local AI service used for LLM intent fallback and voice transcription.
# Docker Compose uses http://qvac:3000 inside the service network.
QVAC_URL=http://localhost:3000

# Public HTTPS URL of the frontend used by Telegram WebApp buttons.
# Railway example: https://your-service.up.railway.app
WEB_APP_URL=

# Internal HTTP API used by the frontend server routes.
BOT_API_PORT=8080
# Optional full backend URL for a standalone frontend service.
# BOT_API_URL=http://localhost:8080

# Starts Next.js frontend when bot/main.py starts.
START_FRONTEND_WITH_BOT=true
FRONTEND_HOST=0.0.0.0
# If FRONTEND_PORT is empty, Railway's PORT is used automatically when present.
FRONTEND_PORT=4000
FRONTEND_DIR=frontend
FRONTEND_MODE=auto
# Optional override, for example:
# FRONTEND_COMMAND=corepack pnpm dev -- --hostname 0.0.0.0 --port $PORT
