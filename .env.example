BOT_TOKEN=
LOG_LEVEL=INFO
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Starts Next.js frontend when bot/main.py starts.
START_FRONTEND_WITH_BOT=true
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=4000
FRONTEND_DIR=frontend
# Optional override, for example:
# FRONTEND_COMMAND=corepack pnpm dev -- --hostname 0.0.0.0 --port 4000
